# ─── Google Gemini ────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ─── Domain Configuration ─────────────────────────────────────
# Comma-separated keywords that define the allowed domain
DOMAIN=health, nutrition, medicine, wellness, diet, fitness
DOMAIN_DESCRIPTION=Health and wellness knowledge base

# ─── Qdrant Vector Database ───────────────────────────────────
#  QDRANT_HOST=localhost -- Use this for dev only. Add below line to /etc/hosts 
#  qdrant-service  127.0.0.1
QDRANT_HOST=qdrant-service
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents

# ─── RAG Parameters ───────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=10
TOP_K_RERANKED=4

# ─── App Server ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8001

# Cache
HF_HOME=.cache/huggingface
SENTENCE_TRANSFORMERS_HOME=.cache/torch/sentence_transformers
GRADIO_TEMP_DIR=.uploads
